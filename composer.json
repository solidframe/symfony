{
    "name": "solidframe/symfony",
    "description": "Symfony bridge for SolidFrame architectural packages",
    "type": "symfony-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "Abdulkadir Posul",
            "email": "abdulkadir-posul@users.noreply.github.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "solidframe/core": "^0.1",
        "symfony/config": "^6.4 || ^7.0",
        "symfony/console": "^6.4 || ^7.0",
        "symfony/dependency-injection": "^6.4 || ^7.0",
        "symfony/http-kernel": "^6.4 || ^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "symfony/framework-bundle": "^6.4 || ^7.0",
        "symfony/yaml": "^6.4 || ^7.0"
    },
    "suggest": {
        "solidframe/ddd": "DDD building blocks (Entity, ValueObject, AggregateRoot)",
        "solidframe/cqrs": "CQRS support (CommandBus, QueryBus)",
        "solidframe/event-driven": "Event-driven architecture (EventBus)",
        "solidframe/event-sourcing": "Event sourcing (EventStore, Snapshots)",
        "solidframe/modular": "Modular monolith support",
        "solidframe/saga": "Saga / Process Manager support",
        "doctrine/dbal": "Required for database-backed stores"
    },
    "autoload": {
        "psr-4": {
            "SolidFrame\\Symfony\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SolidFrame\\Symfony\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        }
    },
    "config": {
        "sort-packages": true
    }
}
